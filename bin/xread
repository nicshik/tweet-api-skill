#!/bin/zsh
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: xread <tweet-url-or-id> [--mode auto|article|tweet]" >&2
  exit 1
fi

PRIMARY_FETCH="$HOME/.codex/skills/twitterapi-x-reader/scripts/twitterapi_fetch.py"
LEGACY_FETCH="$HOME/.codex/skills/twitterapi_x_reader/scripts/twitterapi_fetch.py"

if [[ -f "$PRIMARY_FETCH" ]]; then
  TARGET="$PRIMARY_FETCH"
elif [[ -f "$LEGACY_FETCH" ]]; then
  TARGET="$LEGACY_FETCH"
else
  echo "twitterapi-x-reader is not installed in ~/.codex/skills." >&2
  exit 1
fi

INPUT="$1"
shift

exec python3 "$TARGET" --input "$INPUT" "$@"
