#!/bin/zsh
set -euo pipefail

PRIMARY_CALL="$HOME/.codex/skills/twitterapi-x-reader/scripts/twitterapi_call.py"
LEGACY_CALL="$HOME/.codex/skills/twitterapi_x_reader/scripts/twitterapi_call.py"

if [[ -f "$PRIMARY_CALL" ]]; then
  TARGET="$PRIMARY_CALL"
elif [[ -f "$LEGACY_CALL" ]]; then
  TARGET="$LEGACY_CALL"
else
  echo "twitterapi-x-reader is not installed in ~/.codex/skills." >&2
  exit 1
fi

exec python3 "$TARGET" "$@"
